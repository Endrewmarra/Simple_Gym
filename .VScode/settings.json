{
    // ===== AUTO SAVE =====
    "files.autoSave": "afterDelay",
    "files.autoSaveDelay": 500,

    // ===== WORD WRAP =====
    "editor.wordWrap": "on",
    "editor.wordWrapColumn": 100,

    // ===== CODESPELLING =====
    "cSpell.language": "pt,pt-BR,en",
    "cSpell.enableFiletypes": ["markdown", ".txt"],
    "cSpell.words": [
        "brazilian",
        "CODESPELLING",
        "Endrew",
        "FATECPP"
    ],

    // ===== ARQUIVOS =====
    "files.eol": "\n",
    "files.insertFinalNewline": true,
    "files.trimTrailingWhitespace": true,

    // ===== EDITOR =====
    "editor.tabSize": 4
}
